      <AdditionalIncludeDirectories>$(ProjectDir)\external;$(SolutionDir)\openxr-api-layer;$(SolutionDir)\openxr-api-layer\framework;$(SolutionDir)\external\OpenXR-SDK\include;$(SolutionDir)\external\OpenXR-SDK\src\common;$(SolutionDir)\external\OpenXR-MixedReality\Shared\XrUtility;$(SolutionDir)\external\OpenXR-MixedReality\shared\ext</AdditionalIncludeDirectories>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- d3d11.lib is linked because the template ships ready for
           layers that need D3D11On12CreateDevice (a free function
           exported by d3d11.dll — vtable calls on ID3D11* interfaces
           do not need an import lib, but free-function calls do).
           Layers that never use D3D11On12 still link d3d11.lib at
           zero runtime cost thanks to DelayLoadDLLs: d3d11.dll only
           gets mapped into the test binary the first time you
           actually call D3D11On12CreateDevice / a D3D11 free
           function. delayimp.lib pairs with DelayLoadDLLs. -->
      <AdditionalDependencies>kernel32.lib;user32.lib;advapi32.lib;ole32.lib;oleaut32.lib;uuid.lib;d3d11.lib;delayimp.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <DelayLoadDLLs>d3d11.dll</DelayLoadDLLs>
    </Link>
  </ItemDefinitionGroup>
  <!-- Order-only dependency on the layer project. We compile layer.cpp /
       dispatch.gen.cpp / log.cpp directly into the test binary (so no
       .lib/.dll linking is desired), but the layer project's pre-build step
       generates dispatch.gen.{h,cpp} which we then consume. This reference
       with LinkLibraryDependencies and ReferenceOutputAssembly disabled
       serialises the build without introducing a duplicate-symbol link. -->
  <ItemGroup>
    <ProjectReference Include="..\openxr-api-layer\openxr-api-layer.vcxproj">
      <Project>{93d573d0-634f-4ba0-8fe0-fb63d7d00a05}</Project>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
      <UseLibraryDependencyInputs>false</UseLibraryDependencyInputs>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <!-- doctest driver + tests in this project. Add your own test_*.cpp
         files here — see test_example.cpp for the doctest pattern. -->
    <ClCompile Include="main.cpp" />
    <ClCompile Include="test_example.cpp" />
    <ClCompile Include="mock_runtime.cpp" />
    <ClCompile Include="test_stubs.cpp" />
    <!-- Layer sources we link into the test binary. These define the
         classes the test_*.cpp files exercise. We deliberately do NOT
         pull in framework\entry.cpp (which provides the DLL export
         xrNegotiateLoaderApiLayerInterface) nor framework\dispatch.cpp
         (which talks to the OpenXR loader) — those are loader-only
         code. The stubs in test_stubs.cpp cover the data symbols
         entry.cpp normally defines (dllHome, localAppData,
         log::logStream).
         Add ..\openxr-api-layer\utils\*.cpp entries below as you grow
         your layer with more .cpp files. -->
    <ClCompile Include="..\openxr-api-layer\layer.cpp" />
    <ClCompile Include="..\openxr-api-layer\framework\dispatch.gen.cpp" />
    <ClCompile Include="..\openxr-api-layer\framework\log.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="external\doctest\doctest.h" />
    <ClInclude Include="mock_runtime.h" />
  </ItemGroup>
  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>
