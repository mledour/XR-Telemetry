// =============================================================================
// openxr-api-layer-tests.rc — bundled Rajdhani fonts for the test binary.
//
// The test EXE statically links overlay_renderer.cpp, which loads the
// bundled Rajdhani font via:
//
//     GetModuleHandleEx(GET_MODULE_HANDLE_EX_FLAG_FROM_ADDRESS,
//                        &pickSwapchainFormat, &hMod);
//     FindResource(hMod, MAKEINTRESOURCE(200), MAKEINTRESOURCE(256));
//
// pickSwapchainFormat lives in overlay_renderer.cpp, which is compiled
// into BOTH the layer DLL and this test EXE — so the HMODULE that
// GetModuleHandleEx returns when called from the test binary is the
// test EXE itself, not the layer DLL. Without these resources baked
// into the EXE, FindResource returns null, loadBundledFontCollection
// fails, and the renderer falls back to system Bahnschrift — which
// is what made the first snapshot artifact look "wrong" (system
// condensed sans instead of Rajdhani).
//
// IDs / custom resource type match the layer's openxr-api-layer.rc.in
// exactly (200, RT_BUNDLED_FONT == 256). loadBundledFontCollection
// is therefore identical in both binaries — no test-specific code path.
//
// Why not VERSIONINFO too? The test EXE is never redistributed (it
// runs in CI only), so the Windows-shell version metadata adds no
// value. The fonts are the ONLY resource the test actually needs
// from the .rc — keep this file minimal.
//
// Declarations live in openxr-api-layer/fonts/bundled_fonts.rc.inc — the
// SAME include the layer DLL's openxr-api-layer.rc.in pulls in, so the
// test EXE and the layer DLL bundle IDENTICAL font tables by
// construction. Any divergence between the two (someone adds a font to
// only one side) is now structurally impossible: there is exactly one
// place where fonts are declared. See docs/DEVELOPMENT.md "Adding a new
// bundled resource" for the rationale.
//
// rc.exe resolves both the #include below and the bare-basename TTF
// references inside it via the /I path set in this project's vcxproj
// (ResourceCompile/AdditionalIncludeDirectories points at
// $(SolutionDir)openxr-api-layer\fonts). The layer DLL's vcxproj has
// the SAME /I configuration, so the #include statement is symmetric
// across the two binaries — neither side needs a fragile relative
// path that would break if the .rc files moved within the tree.
// =============================================================================

#include "bundled_fonts.rc.inc"
