  <ItemGroup>
    <!-- Histogram-bar shaders. Compiled offline by FxCompile (no runtime
         D3DCompile / d3dcompiler dependency) into embedded bytecode headers
         under $(IntDir): overlay_bars_vs.h / overlay_bars_ps.h, each exposing
         a `const BYTE g_<filename>[]` array (VariableName below). The C++
         HistogramBarRenderer includes those headers to create the shaders;
         $(IntDir) is added to the C++ include path once the renderer lands.
         Shader Model 4.0 = feature level 10_0, the broadest target that still
         supports the input-layout instancing we use (no 5.0 features needed)
         — keeps the layer loadable on the widest range of OpenXR hosts. -->
    <FxCompile Include="shaders\overlay_bars_vs.hlsl">
      <ShaderType>Vertex</ShaderType>
      <ShaderModel>4.0</ShaderModel>
      <EntryPointName>VSMain</EntryPointName>
      <HeaderFileOutput>$(IntDir)%(Filename).h</HeaderFileOutput>
      <VariableName>g_%(Filename)</VariableName>
      <ObjectFileOutput>
      </ObjectFileOutput>
    </FxCompile>
