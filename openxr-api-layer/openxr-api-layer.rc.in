// openxr-api-layer.rc.in
//
// Template for the DLL's VERSIONINFO resource. The adjacent script
// scripts\Generate-VersionRc.ps1 substitutes @VERSION_MAJOR@, @VERSION_MINOR@,
// @VERSION_PATCH@, @VERSION_STRING@, and @SOLUTION_NAME@ at pre-build time
// and writes the result to openxr-api-layer.rc (which is .gitignore'd).
//
// Do NOT edit the generated openxr-api-layer.rc by hand — edits will be
// clobbered on the next build. Edit this template and/or the generator
// script instead.

#include <winver.h>

#define VER_FILEVERSION         @VERSION_MAJOR@,@VERSION_MINOR@,@VERSION_PATCH@,0
#define VER_FILEVERSION_STR     "@VERSION_STRING@\0"
#define VER_PRODUCTVERSION      @VERSION_MAJOR@,@VERSION_MINOR@,@VERSION_PATCH@,0
#define VER_PRODUCTVERSION_STR  "@VERSION_STRING@\0"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    VER_FILEVERSION
 PRODUCTVERSION VER_PRODUCTVERSION
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_DLL
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 040904B0: US English (0x0409) + Unicode (0x04B0).
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Michael Ledour\0"
            VALUE "FileDescription",  "OpenXR layer that narrows effective FOV and swapchain resolution to reduce GPU load\0"
            VALUE "FileVersion",      VER_FILEVERSION_STR
            VALUE "InternalName",     "xr_telemetry\0"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Michael Ledour. MIT License.\0"
            VALUE "OriginalFilename", "@SOLUTION_NAME@.dll\0"
            VALUE "ProductName",      "@SOLUTION_NAME@\0"
            VALUE "ProductVersion",   VER_PRODUCTVERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// -----------------------------------------------------------------------------
// Bundled fonts — Rajdhani (SIL Open Font License, see fonts/OFL.txt).
// Subsetted to ASCII + °/µ/× glyphs (~11 KB each) so the DLL doesn't pay the
// full multi-script weight (~400 KB original).
//
// IDs 200/201 are used at runtime via FindResource(...) +
// IDWriteFactory5::CreateInMemoryFontFileLoader — see overlay_renderer.cpp.
//
// Declarations live in the shared include below — the SAME file is included
// by openxr-api-layer-tests.rc so the test EXE and the layer DLL bundle
// IDENTICAL font tables. Adding a new font / changing an ID / removing a
// resource: edit bundled_fonts.rc.inc once and BOTH binaries pick it up.
// See docs/DEVELOPMENT.md "Adding a new bundled resource".
//
// rc.exe resolves both the #include below and the bare-basename TTF
// references inside it via the /I path set in this project's vcxproj
// (ResourceCompile/AdditionalIncludeDirectories points at
// $(SolutionDir)openxr-api-layer\fonts). Same /I configuration in the
// test EXE's vcxproj, so the #include statement is symmetric — neither
// side needs a relative path that would break if the .rc files moved.
//
// (An earlier attempt used a FONTS_PREFIX macro counting on rc.exe
// concatenating adjacent string literals the way the C compiler does;
// rc.exe does NOT do that, and the build fails with RC2135 file-not-
// found. /I is the rc.exe-documented mechanism.)
// -----------------------------------------------------------------------------
#include "bundled_fonts.rc.inc"
